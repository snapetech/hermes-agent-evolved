# Public-safe example values for Hermes Evolved reproduction checks.
#
# Copy to an untracked local file such as values.local.env, fill in real
# operator-owned values, then source it before running the prereq and smoke
# scripts. Do not commit real secrets, hostnames, tokens, channel IDs, or user
# IDs.

NAMESPACE=hermes
IMAGE_REF=registry.example.com/hermes-agent-sudo:replace-me
MODEL_BASE_URL=https://model-endpoint.example/v1
FIRECRAWL_API_URL=https://firecrawl.example

# Set to 1 only when these integrations are part of the reproduction target.
REQUIRE_DISCORD=0
REQUIRE_FIRECRAWL=0

# Static manifest-only checks can skip live model reachability.
STATIC_ONLY=0
SKIP_MODEL_CHECK=0

# Public example secret names. The values live in Kubernetes Secrets, not here.
API_SECRET=hermes-api-server
DISCORD_SECRET=hermes-discord

# Optional smoke-test values.
DEPLOYMENT=hermes-gateway
CONTAINER=gateway
SERVICE=hermes-gateway
LOCAL_PORT=18642
RUN_MODEL_CHECK=1
API_KEY=
